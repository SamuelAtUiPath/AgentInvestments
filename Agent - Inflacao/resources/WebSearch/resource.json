{
  "$resourceType": "tool",
  "name": "WebSearch",
  "description": "Searches the public web using a natural-language query and returns relevant results with source links. Use this tool for every external lookup needed to find Brazilian macroeconomic data, including IPCA monthly variation, IPCA accumulated over 12 months for a requested month and year, market expectations for that monthly IPCA result, and the current annual SELIC rate. Prefer official or highly reliable sources such as IBGE, Banco Central do Brasil, official government pages, or reputable financial/news outlets. Provide a clear query, avoid unnecessary site restrictions, and keep the returned links so they can be included in the agent output.",
  "location": "external",
  "type": "integration",
  "inputSchema": {
    "type": "object",
    "properties": {
      "provider": {
        "type": "string",
        "title": "Search Engine",
        "description": "The search engine to use",
        "enum": [
          "GoogleCustomSearch"
        ],
        "oneOf": [
          {
            "const": "GoogleCustomSearch",
            "title": "GoogleCustomSearch"
          }
        ]
      },
      "query": {
        "type": "string",
        "title": "Search",
        "description": "The natural language query to search the web for"
      },
      "num": {
        "type": "integer",
        "title": "Number of results",
        "description": "1."
      },
      "start": {
        "type": "integer",
        "title": "Start",
        "description": "First result index (pagination)."
      },
      "siteSearch": {
        "type": "string",
        "title": "Site Search",
        "description": "Optionally restrict the search to a specific site or domain, such as ibge.gov.br or bcb.gov.br. Leave blank when broader web search is needed."
      },
      "siteSearchFilter": {
        "type": "string",
        "title": "Site Search Filter",
        "description": "Either \"i\" (include) or \"e\" (exclude)."
      }
    },
    "required": [
      "provider",
      "query"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "formattedResults": {
        "type": "string",
        "title": "Formatted results",
        "description": "The search results string containing title, URL, and snippet"
      },
      "results[*]": {
        "type": "array",
        "title": "Results",
        "items": {
          "$ref": "#/definitions/results[*]"
        }
      }
    },
    "definitions": {
      "results[*]": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "title": "Result title",
            "description": "The title of a search result item."
          },
          "snippet": {
            "type": "string",
            "title": "Result snippet",
            "description": "A brief summary or excerpt of a search result item."
          },
          "url": {
            "type": "string",
            "title": "Result url",
            "description": "The web address of the search result."
          }
        }
      }
    }
  },
